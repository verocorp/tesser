#!/usr/bin/env python3
"""tesser setup — one-time environment setup (D32).

Creates the private virtualenv at <state root>/venv (state root: ~/.tesser/,
or TESSER_HOME — the tests-only override, same rule as the other scripts) and
installs requirements.txt into it. scripts/validate-digest re-execs into this
venv's python, so its dependencies never touch the system interpreter.

Idempotent on the requirements hash: the venv carries a stamp file
(.requirements-sha256) recording the sha256 of requirements.txt it was
installed from. Re-running with an unchanged requirements.txt is a no-op;
a changed requirements.txt triggers a reinstall and a new stamp. The venv
is only CREATED when its python is missing — a reinstall into an existing
venv does not recreate it.

Exit codes: 0 success (including no-op), 1 setup failure.
Stdlib only — this script must run before any dependency exists.
"""

import hashlib
import os
import subprocess
import sys

STAMP_NAME = ".requirements-sha256"


def state_root() -> str:
    """Resolve the state root: TESSER_HOME (tests only) or ~/.tesser/."""
    override = os.environ.get("TESSER_HOME")
    if override:
        return override
    return os.path.join(os.path.expanduser("~"), ".tesser")


def link_companion_skills(repo_root: str) -> None:
    """Make the nested companion skills (tesser-review/, tesser-finalize/)
    discoverable. Claude Code scans skills only one level deep, so a companion
    nested inside this repo is invisible until it is linked up to a top-level
    entry beside the `tesser` skill.

    Auto-wiring happens ONLY for the documented personal install (git clone ->
    ~/.claude/skills/tesser): the companions are linked as siblings there. If
    tesser is NOT installed at ~/.claude/skills/tesser — e.g. a dev checkout
    symlinked project-scoped into some project's .claude/skills — this is a
    no-op: setup neither guesses a project's skills dir nor clutters
    ~/.claude/skills. TESSER_SKILLS_DIR forces the target (tests). Best-effort:
    a failure here never fails setup (the venv is the critical part).
    """
    forced = os.environ.get("TESSER_SKILLS_DIR")
    if forced:
        skills_dir = forced
    else:
        personal = os.path.join(os.path.expanduser("~"), ".claude", "skills")
        tesser_link = os.path.join(personal, "tesser")
        if not (
            os.path.lexists(tesser_link)
            and os.path.realpath(tesser_link) == os.path.realpath(repo_root)
        ):
            return  # not the documented personal install — leave the environment alone
        skills_dir = personal
    try:
        os.makedirs(skills_dir, exist_ok=True)
    except OSError as e:
        sys.stderr.write(f"setup: could not prepare skills dir {skills_dir}: {e}\n")
        return
    for name in ("tesser-review", "tesser-finalize"):
        target = os.path.join(repo_root, name)
        link = os.path.join(skills_dir, name)
        if not os.path.isdir(target):
            continue  # companion absent in this checkout; skip
        try:
            if os.path.islink(link):
                if os.path.realpath(link) == os.path.realpath(target):
                    continue  # already correct
                os.unlink(link)
            elif os.path.exists(link):
                # A real directory/file we did not create — never clobber it.
                sys.stderr.write(
                    f"setup: {link} exists and is not our symlink; leaving it "
                    f"(/{name} may not resolve to this repo)\n"
                )
                continue
            os.symlink(target, link)
            print(f"setup: linked /{name} -> {target}")
        except OSError as e:
            sys.stderr.write(f"setup: could not link /{name}: {e}\n")


def main() -> int:
    repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    requirements = os.path.join(repo_root, "requirements.txt")
    if not os.path.isfile(requirements):
        sys.stderr.write(f"setup: requirements.txt not found at {requirements}\n")
        return 1
    with open(requirements, "rb") as f:
        req_hash = hashlib.sha256(f.read()).hexdigest()

    root = state_root()
    venv = os.path.join(root, "venv")
    venv_python = os.path.join(venv, "bin", "python3")
    stamp_path = os.path.join(venv, STAMP_NAME)

    stamp = None
    if os.path.isfile(stamp_path):
        with open(stamp_path, "r", encoding="utf-8") as f:
            stamp = f.read().strip()
    if os.access(venv_python, os.X_OK) and stamp == req_hash:
        print(f"setup: venv at {venv} is up to date (requirements unchanged)")
        link_companion_skills(repo_root)
        return 0

    # The log may live next to the venv; keep the state root private (0700,
    # same posture as scripts/log-invocation).
    os.makedirs(root, mode=0o700, exist_ok=True)

    if not os.access(venv_python, os.X_OK):
        print(f"setup: creating venv at {venv}")
        created = subprocess.run([sys.executable, "-m", "venv", venv])
        if created.returncode != 0:
            sys.stderr.write(f"setup: venv creation failed (exit {created.returncode})\n")
            return 1

    print(f"setup: installing requirements.txt into {venv}")
    pip = os.path.join(venv, "bin", "pip")
    installed = subprocess.run([pip, "install", "--quiet", "-r", requirements])
    if installed.returncode != 0:
        sys.stderr.write(
            f"setup: pip install failed (exit {installed.returncode}); "
            "no stamp written — re-run scripts/setup\n"
        )
        return 1

    # Stamp last, only after a successful install: a failed install must
    # leave the venv unstamped so the next run retries.
    with open(stamp_path, "w", encoding="utf-8") as f:
        f.write(req_hash + "\n")
    link_companion_skills(repo_root)
    print("setup: done")
    return 0


if __name__ == "__main__":
    sys.exit(main())
